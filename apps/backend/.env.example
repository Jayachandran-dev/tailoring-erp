# --- Server ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- Database (PostgreSQL) ---
# Used as the BASE url. Schema is appended at runtime per tenant.
# Example: postgresql://postgres:postgres@localhost:5432/tailoring_erp
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tailoring_erp?schema=public"

# Base URL WITHOUT ?schema=... (the app appends it). Same DB, different schemas.
DATABASE_BASE_URL="postgresql://postgres:postgres@localhost:5432/tailoring_erp"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# --- OTP ---
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
# 'mock' prints OTP to console & returns it in dev responses.
# Plug in 'twilio' | 'msg91' | 'fast2sms' later.
SMS_PROVIDER=mock
# When true (dev only), API responses include the OTP for easy testing.
OTP_EXPOSE_IN_RESPONSE=true
