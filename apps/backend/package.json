{
  "name": "@tailoring-erp/backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "platform:generate": "prisma generate --schema=prisma/platform/schema.prisma",
    "platform:migrate": "prisma migrate dev --schema=prisma/platform/schema.prisma --name init",
    "platform:deploy": "prisma migrate deploy --schema=prisma/platform/schema.prisma",
    "tenant:generate": "prisma generate --schema=prisma/tenant/schema.prisma",
    "postinstall": "npm run platform:generate && npm run tenant:generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
